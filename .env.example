# Single PAT for all Azure operations: REST API + git credentials + X-Agent-Token auth
TOKEN_AZURE=changeme

# Azure DevOps
AZURE_ORG=ZurichInsurance-EC
AZURE_PROJECT=Oficina-Virtual-ZEC

# Git credentials — username for HTTPS git operations
GIT_USERNAME=

# SQLite task persistence — mount /data as a Docker volume
TASKS_DB=/data/tasks.db

# HTTP port
PORT=5000

# TLS verification for callback POSTs: "true" | "false" | /path/to/ca-bundle.pem
CALLBACK_VERIFY_SSL=true

# Retention period for task records and uploads
RETENTION_DAYS=90
